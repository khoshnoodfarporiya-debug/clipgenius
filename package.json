{
  "name": "clipgenius",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/proxy.js\" \"vite\"",
    "dev:frontend": "vite",
    "dev:backend": "node server/proxy.js",
    "build": "vite build",
    "start": "node server/proxy.js",
    "cap:install": "npm install @capacitor/core @capacitor/cli @capacitor/ios",
    "cap:init": "npx cap init ClipGenius com.clipgenius.app --web-dir=dist",
    "cap:add-ios": "npx cap add ios",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open-ios": "npx cap open ios"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vite": "^5.4.0"
  }
}
